# Ethiopian Coffee Export Consortium Blockchain System (CECBS)
# API Gateway Environment Configuration

# Server Configuration
NODE_ENV=development
PORT=3001
API_BASE_URL=http://localhost:3001/api/v1

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# JWT Configuration
JWT_SECRET=cecbs-secret-key-change-in-production
JWT_EXPIRY=24h

# Hyperledger Fabric Configuration
FABRIC_WALLET_PATH=./wallet
FABRIC_CCP_PATH=../blockchain/organizations/peerOrganizations/ecta.cecbs.et/connection-ecta.json
FABRIC_CHANNEL_NAME=coffeechannel
FABRIC_CHAINCODE_NAME=coffee
FABRIC_MSP_ID=ECTAMSP
FABRIC_CA_URL=https://localhost:7054

# Database Configuration (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cecbs
DB_USER=cecbs_user
DB_PASSWORD=cecbs_password

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Logging Configuration
LOG_LEVEL=info
LOG_DIR=./logs

# File Upload Configuration
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# WebSocket Configuration
WS_PORT=3002

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000
BLOCKCHAIN_RATE_LIMIT_MAX=100

# Security
BCRYPT_ROUNDS=10
SESSION_SECRET=cecbs-session-secret-change-in-production

# External Services
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@cecbs.et
SMTP_PASSWORD=
SMTP_FROM=CECBS <noreply@cecbs.et>

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090

# Feature Flags
ENABLE_SWAGGER=true
ENABLE_WEBSOCKET=true
ENABLE_FILE_UPLOAD=true

# Document Storage Configuration
# IPFS (InterPlanetary File System) - Distributed document storage
USE_IPFS=false
IPFS_HOST=localhost
IPFS_PORT=5001
IPFS_GATEWAY=https://ipfs.io/ipfs/
DOCUMENT_ENCRYPTION_KEY=change_this_to_64_character_hex_string_for_production_use
# To enable IPFS:
# 1. Install IPFS: https://docs.ipfs.tech/install/
# 2. Start IPFS daemon: ipfs daemon
# 3. Set USE_IPFS=true
