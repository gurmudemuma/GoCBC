# ============================================================
# CECBS API Server - Environment Configuration
# ============================================================
#
# INSTRUCTIONS:
# 1. Copy this file to .env for development
# 2. Copy this file to .env.production for production
# 3. Update values based on your environment
# 4. Never commit .env or .env.production to git
#
# ============================================================

# ==================== SERVER CONFIGURATION ====================

# Environment mode: development | production | test
NODE_ENV=development

# Server port (localhost only, nginx proxies externally)
PORT=3001

# API Base URL (for internal use)
# Development:
#   API_BASE_URL=http://localhost:3001/api/v1
# Production (via nginx):
#   API_BASE_URL=http://10.3.15.7/api/v1

API_BASE_URL=http://localhost:3001/api/v1

# Production - Uncomment:
# API_BASE_URL=http://10.3.15.7/api/v1

# ==================== CORS CONFIGURATION ====================

# Allowed origins for CORS
# Development:
#   ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
# Production:
#   ALLOWED_ORIGINS=http://10.3.15.7,https://coffeex.cbe.com.et

ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Production - Uncomment and customize:
# ALLOWED_ORIGINS=http://10.3.15.7,https://coffeex.cbe.com.et

# ==================== JWT CONFIGURATION ====================

# JWT secret key for token signing
# IMPORTANT: Change this in production!
# Generate with: openssl rand -base64 32
JWT_SECRET=cecbs-secret-key-change-in-production-use-at-least-32-characters

# JWT expiry time
JWT_EXPIRY=24h

# Refresh token expiry
REFRESH_TOKEN_EXPIRY=7d

# ==================== HYPERLEDGER FABRIC CONFIGURATION ====================

# Enable Fabric blockchain integration
# Set to false when blockchain network is not running
FABRIC_ENABLED=true

# Require Fabric on startup (fail if unavailable)
# Set to false for graceful degradation
FABRIC_REQUIRED=false

# Use localhost for Fabric peers
# Set to false when running inside Docker
FABRIC_AS_LOCALHOST=true

# Fabric wallet path
FABRIC_WALLET_PATH=./wallet

# Fabric connection profile path
FABRIC_CCP_PATH=../blockchain/organizations/peerOrganizations/ecta.cecbs.et/connection-ecta.json

# Fabric channel name
FABRIC_CHANNEL_NAME=coffeechannel

# Fabric chaincode name
FABRIC_CHAINCODE_NAME=coffee

# Fabric MSP ID
FABRIC_MSP_ID=ECTAMSP

# Fabric CA URL
FABRIC_CA_URL=https://localhost:7054

# ==================== DATABASE CONFIGURATION ====================

# SQLite database path (for local development)
DATABASE_PATH=./cecbs.db

# For PostgreSQL (production option):
# DB_TYPE=postgresql
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=cecbs
# DB_USER=cecbs_user
# DB_PASSWORD=your_secure_password_here

# For MySQL (production option):
# DB_TYPE=mysql
# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=cecbs
# DB_USER=cecbs_user
# DB_PASSWORD=your_secure_password_here

# ==================== LOGGING CONFIGURATION ====================

# Log level: error | warn | info | debug | verbose
LOG_LEVEL=info

# Log directory
LOG_DIR=./logs

# Log rotation (days)
LOG_MAX_FILES=30

# Log max size (MB)
LOG_MAX_SIZE=10

# ==================== FILE UPLOAD CONFIGURATION ====================

# Upload directory
UPLOAD_DIR=./uploads

# Maximum file size (bytes) - 50MB
MAX_FILE_SIZE=52428800

# Allowed file types (comma-separated)
ALLOWED_FILE_TYPES=pdf,doc,docx,xls,xlsx,jpg,jpeg,png,zip

# ==================== WEBSOCKET CONFIGURATION ====================

# WebSocket server port
WS_PORT=3002

# Enable WebSocket server
ENABLE_WEBSOCKET=true

# ==================== RATE LIMITING ====================

# Rate limit window (milliseconds) - 15 minutes
RATE_LIMIT_WINDOW_MS=900000

# Maximum requests per window
RATE_LIMIT_MAX_REQUESTS=1000

# Blockchain-specific rate limit
BLOCKCHAIN_RATE_LIMIT_MAX=100

# ==================== SECURITY ====================

# BCrypt rounds for password hashing
BCRYPT_ROUNDS=10

# Session secret
# IMPORTANT: Change this in production!
# Generate with: openssl rand -base64 32
SESSION_SECRET=cecbs-session-secret-change-in-production-use-at-least-32-characters

# Enable helmet security headers
ENABLE_HELMET=true

# HTTPS redirect (production only)
FORCE_HTTPS=false

# ==================== FEATURE FLAGS ====================

# Enable Swagger API documentation
ENABLE_SWAGGER=true

# Enable WebSocket for real-time updates
ENABLE_WEBSOCKET=true

# Enable file upload endpoints
ENABLE_FILE_UPLOAD=true

# Enable blockchain explorer APIs
ENABLE_BLOCKCHAIN_EXPLORER=true

# ==================== IPFS CONFIGURATION ====================

# Use IPFS for document storage
USE_IPFS=true

# IPFS host
IPFS_HOST=localhost

# IPFS API port
IPFS_PORT=5001

# IPFS protocol
IPFS_PROTOCOL=http

# IPFS Gateway URL
IPFS_GATEWAY=http://localhost:8080/ipfs/

# Production (via nginx):
# IPFS_GATEWAY=http://10.3.15.7/ipfs/

# Document encryption key (64 characters hex string)
# IMPORTANT: Change this in production!
# Generate with: openssl rand -hex 32
DOCUMENT_ENCRYPTION_KEY=cecbs_document_encryption_key_2026_change_in_production_64chars

# ==================== EXTERNAL SERVICES ====================

# SMTP Configuration (for email notifications)
SMTP_ENABLED=false
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@cecbs.et
SMTP_PASSWORD=
SMTP_FROM=CECBS <noreply@cecbs.et>

# SMS Configuration (for SMS notifications)
SMS_ENABLED=false
SMS_PROVIDER=twilio
SMS_ACCOUNT_SID=
SMS_AUTH_TOKEN=
SMS_FROM_NUMBER=

# ==================== REDIS CONFIGURATION ====================

# Redis for session storage and caching (optional)
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ==================== MONITORING ====================

# Enable metrics endpoint
ENABLE_METRICS=false

# Metrics port
METRICS_PORT=9090

# Health check endpoint
HEALTH_CHECK_ENABLED=true

# ==================== ETHEREUM/ERC-20 INTEGRATION ====================

# Enable Ethereum integration (if needed)
ETHEREUM_ENABLED=false
ETHEREUM_NETWORK=mainnet
ETHEREUM_RPC_URL=
ETHEREUM_CONTRACT_ADDRESS=
ETHEREUM_PRIVATE_KEY=

# ==================== PAYMENT GATEWAY ====================

# Payment gateway integration (if needed)
PAYMENT_GATEWAY_ENABLED=false
PAYMENT_GATEWAY_PROVIDER=stripe
PAYMENT_GATEWAY_API_KEY=
PAYMENT_GATEWAY_WEBHOOK_SECRET=

# ==================== INTERNATIONALIZATION ====================

# Default language
DEFAULT_LOCALE=en

# Supported languages
SUPPORTED_LOCALES=en,am

# Timezone
TIMEZONE=Africa/Addis_Ababa

# ==================== BACKUP CONFIGURATION ====================

# Auto backup enabled
AUTO_BACKUP_ENABLED=false

# Backup directory
BACKUP_DIR=./backups

# Backup schedule (cron expression) - Daily at 2 AM
BACKUP_SCHEDULE=0 2 * * *

# ==================== PRODUCTION DEPLOYMENT NOTES ====================
#
# When deploying to production server (10.3.15.7):
#
# 1. Update critical values:
#    NODE_ENV=production
#    JWT_SECRET=<generate_secure_32_char_string>
#    SESSION_SECRET=<generate_secure_32_char_string>
#    DOCUMENT_ENCRYPTION_KEY=<generate_secure_64_char_hex>
#
# 2. Update URLs:
#    API_BASE_URL=http://10.3.15.7/api/v1
#    ALLOWED_ORIGINS=http://10.3.15.7
#    IPFS_GATEWAY=http://10.3.15.7/ipfs/
#
# 3. Configure database:
#    - Use PostgreSQL or MySQL instead of SQLite
#    - Set strong DB_PASSWORD
#
# 4. Enable production features:
#    FORCE_HTTPS=true (after SSL setup)
#    ENABLE_METRICS=true
#    AUTO_BACKUP_ENABLED=true
#
# 5. Configure external services:
#    - SMTP for email notifications
#    - Redis for caching (recommended)
#
# 6. Security checklist:
#    - Change all default secrets
#    - Enable HTTPS
#    - Configure firewall
#    - Enable rate limiting
#    - Set up monitoring
#
# ============================================================
