# ============================================================
# CECBS API Server - Production Environment Configuration
# Domain: coffeex.cbe.com.et (Server: 10.3.15.7)
# ============================================================
#
# INSTRUCTIONS:
# 1. Copy this file to .env.production on production server
# 2. Generate secure secrets (see commands at bottom)
# 3. Choose HTTP or HTTPS configuration based on your setup
# 4. Never commit .env.production to git
#
# ============================================================

# ==================== SERVER CONFIGURATION ====================

# Environment mode
NODE_ENV=production

# Server port (localhost only, nginx proxies externally)
PORT=3001

# ==================== API URLs ====================

# OPTION 1: Production HTTP (via IP)
# API_BASE_URL=http://10.3.15.7/api/v1

# OPTION 2: Production HTTPS (via domain - RECOMMENDED)
API_BASE_URL=https://coffeex.cbe.com.et/api/v1

# ==================== CORS CONFIGURATION ====================

# OPTION 1: HTTP origins
# ALLOWED_ORIGINS=http://10.3.15.7

# OPTION 2: HTTPS origins (RECOMMENDED)
ALLOWED_ORIGINS=https://coffeex.cbe.com.et

# ==================== JWT CONFIGURATION ====================

# JWT secret key for token signing
# IMPORTANT: Generate with: openssl rand -base64 32
JWT_SECRET=REPLACE_WITH_SECURE_SECRET_32_CHARS

# JWT expiry time
JWT_EXPIRY=24h

# Refresh token expiry
REFRESH_TOKEN_EXPIRY=7d

# ==================== SESSION SECURITY ====================

# Session secret
# IMPORTANT: Generate with: openssl rand -base64 32
SESSION_SECRET=REPLACE_WITH_SECURE_SECRET_32_CHARS

# BCrypt rounds for password hashing
BCRYPT_ROUNDS=12

# ==================== HYPERLEDGER FABRIC CONFIGURATION ====================

# Enable Fabric blockchain integration
FABRIC_ENABLED=true

# Require Fabric on startup
FABRIC_REQUIRED=false

# Use localhost for Fabric peers (true in production)
FABRIC_AS_LOCALHOST=true

# Fabric configuration paths
FABRIC_WALLET_PATH=./wallet
FABRIC_CCP_PATH=../blockchain/organizations/peerOrganizations/ecta.cecbs.et/connection-ecta.json
FABRIC_CHANNEL_NAME=coffeechannel
FABRIC_CHAINCODE_NAME=coffee
FABRIC_MSP_ID=ECTAMSP
FABRIC_CA_URL=https://localhost:7054

# ==================== DATABASE CONFIGURATION ====================

# Use PostgreSQL in production (recommended)
DB_TYPE=postgresql
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cecbs_production
DB_USER=cecbs_user
DB_PASSWORD=REPLACE_WITH_SECURE_DB_PASSWORD

# Fallback to SQLite (not recommended for production)
# DATABASE_PATH=./cecbs.db

# ==================== LOGGING CONFIGURATION ====================

# Production log level
LOG_LEVEL=warn

# Log directory
LOG_DIR=./logs

# Log rotation (days)
LOG_MAX_FILES=60

# Log max size (MB)
LOG_MAX_SIZE=50

# ==================== FILE UPLOAD CONFIGURATION ====================

# Upload directory
UPLOAD_DIR=./uploads

# Maximum file size (bytes) - 50MB
MAX_FILE_SIZE=52428800

# Allowed file types
ALLOWED_FILE_TYPES=pdf,doc,docx,xls,xlsx,jpg,jpeg,png,zip

# ==================== WEBSOCKET CONFIGURATION ====================

# WebSocket server port
WS_PORT=3002

# Enable WebSocket server
ENABLE_WEBSOCKET=true

# ==================== RATE LIMITING ====================

# Rate limit window (milliseconds) - 15 minutes
RATE_LIMIT_WINDOW_MS=900000

# Maximum requests per window (stricter in production)
RATE_LIMIT_MAX_REQUESTS=500

# Blockchain-specific rate limit
BLOCKCHAIN_RATE_LIMIT_MAX=50

# ==================== SECURITY ====================

# Enable helmet security headers
ENABLE_HELMET=true

# Force HTTPS redirect (enable after SSL setup)
FORCE_HTTPS=true

# ==================== FEATURE FLAGS ====================

# Disable Swagger in production
ENABLE_SWAGGER=false

# Enable production features
ENABLE_WEBSOCKET=true
ENABLE_FILE_UPLOAD=true
ENABLE_BLOCKCHAIN_EXPLORER=false
ENABLE_METRICS=true

# ==================== IPFS CONFIGURATION ====================

# Use IPFS for document storage
USE_IPFS=true

# IPFS connection
IPFS_HOST=localhost
IPFS_PORT=5001
IPFS_PROTOCOL=http

# OPTION 1: IPFS Gateway via IP
# IPFS_GATEWAY=http://10.3.15.7/ipfs/

# OPTION 2: IPFS Gateway via domain (RECOMMENDED)
IPFS_GATEWAY=https://coffeex.cbe.com.et/ipfs/

# Document encryption key (64 characters hex string)
# IMPORTANT: Generate with: openssl rand -hex 32
DOCUMENT_ENCRYPTION_KEY=REPLACE_WITH_64_CHAR_HEX_KEY

# ==================== EXTERNAL SERVICES ====================

# SMTP Configuration (for email notifications)
SMTP_ENABLED=true
SMTP_HOST=smtp.cbe.com.et
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@coffeex.cbe.com.et
SMTP_PASSWORD=REPLACE_WITH_EMAIL_PASSWORD
SMTP_FROM=CoffeeX CECBS <noreply@coffeex.cbe.com.et>

# ==================== REDIS CONFIGURATION ====================

# Redis for session storage and caching (recommended for production)
REDIS_ENABLED=true
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=REPLACE_WITH_REDIS_PASSWORD
REDIS_DB=0

# ==================== MONITORING ====================

# Enable metrics endpoint
ENABLE_METRICS=true

# Metrics port (internal only)
METRICS_PORT=9090

# Health check endpoint
HEALTH_CHECK_ENABLED=true

# ==================== BACKUP CONFIGURATION ====================

# Auto backup enabled
AUTO_BACKUP_ENABLED=true

# Backup directory
BACKUP_DIR=./backups

# Backup schedule (cron expression) - Daily at 3 AM
BACKUP_SCHEDULE=0 3 * * *

# ==================== INTERNATIONALIZATION ====================

# Default language
DEFAULT_LOCALE=en

# Supported languages
SUPPORTED_LOCALES=en,am

# Timezone
TIMEZONE=Africa/Addis_Ababa

# ============================================================
# SECURITY CHECKLIST - GENERATE THESE SECRETS!
# ============================================================
#
# 1. Generate JWT Secret:
#    openssl rand -base64 32
#
# 2. Generate Session Secret:
#    openssl rand -base64 32
#
# 3. Generate Document Encryption Key:
#    openssl rand -hex 32
#
# 4. Create database user and password:
#    sudo -u postgres createuser cecbs_user
#    sudo -u postgres createdb cecbs_production -O cecbs_user
#    sudo -u postgres psql -c "ALTER USER cecbs_user PASSWORD 'SECURE_PASSWORD';"
#
# 5. Setup Redis password:
#    redis-cli config set requirepass SECURE_REDIS_PASSWORD
#
# ============================================================
# QUICK DEPLOYMENT COMMANDS
# ============================================================
#
# 1. Copy to production server:
#    scp .env.production.example root@10.3.15.7:/opt/cecbs/api/.env.production
#
# 2. Edit secrets on server:
#    nano /opt/cecbs/api/.env.production
#
# 3. Start production server:
#    cd /opt/cecbs/api && npm start
#
# ============================================================