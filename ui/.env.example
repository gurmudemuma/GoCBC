# ============================================================
# CECBS Next.js UI - Environment Configuration
# ============================================================
# 
# INSTRUCTIONS:
# 1. Copy this file to .env.local (for development)
# 2. Copy this file to .env.production (for production)
# 3. Update values based on your environment
# 4. Never commit .env.local or .env.production to git
#
# ============================================================

# ==================== ENVIRONMENT MODE ====================
# Development: Use when running on localhost
# Production: Use when deploying to server
# Set by Next.js automatically based on NODE_ENV
# NODE_ENV=development  # or production

# ==================== API CONFIGURATION ====================

# API Base URL - ENVIRONMENT AWARE
# Development (localhost):
#   NEXT_PUBLIC_API_BASE_URL=http://localhost:3001/api/v1
# Production (via nginx on server 10.3.15.7):
#   NEXT_PUBLIC_API_BASE_URL=http://10.3.15.7/api/v1
# Production (with domain and nginx):
#   NEXT_PUBLIC_API_BASE_URL=https://coffeex.cbe.com.et/api/v1

# For Development (localhost)
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001/api/v1

# For Production - Uncomment and use ONE of these:
# NEXT_PUBLIC_API_BASE_URL=http://10.3.15.7/api/v1
# NEXT_PUBLIC_API_BASE_URL=https://coffeex.cbe.com.et/api/v1

# Legacy API URL (for backward compatibility)
CECBS_API_URL=http://localhost:3001/api/v1

# ==================== WEBSOCKET CONFIGURATION ====================

# WebSocket URL for real-time updates
# Development:
#   NEXT_PUBLIC_WS_URL=ws://localhost:3002
# Production (via nginx):
#   NEXT_PUBLIC_WS_URL=ws://10.3.15.7/socket.io
# Production (with SSL):
#   NEXT_PUBLIC_WS_URL=wss://coffeex.cbe.com.et/socket.io

NEXT_PUBLIC_WS_URL=ws://localhost:3002

# Production - Uncomment ONE of these:
# NEXT_PUBLIC_WS_URL=ws://10.3.15.7/socket.io
# NEXT_PUBLIC_WS_URL=wss://coffeex.cbe.com.et/socket.io

# ==================== APPLICATION INFO ====================

NEXT_PUBLIC_APP_NAME=CECBS
NEXT_PUBLIC_APP_VERSION=1.2.0
NEXT_PUBLIC_APP_DESCRIPTION=Ethiopian Coffee Export Consortium Blockchain System

# ==================== FEATURE FLAGS ====================

# Enable/disable features
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_WEBSOCKET=true
NEXT_PUBLIC_ENABLE_QR_CODE=true
NEXT_PUBLIC_ENABLE_BLOCKCHAIN_EXPLORER=true
NEXT_PUBLIC_ENABLE_IPFS=true

# ==================== ORGANIZATION CONFIG ====================

# Default organization portal on login
NEXT_PUBLIC_DEFAULT_ORG=ECTA

# Supported organizations
NEXT_PUBLIC_SUPPORTED_ORGS=ECTA,ECX,NBE,BANKS,CUSTOMS,SHIPPING

# ==================== MAP CONFIGURATION ====================

# Mapbox access token (optional - for map features)
# Get token from: https://account.mapbox.com/access-tokens/
NEXT_PUBLIC_MAPBOX_TOKEN=

# Default map center (Addis Ababa, Ethiopia)
NEXT_PUBLIC_DEFAULT_MAP_CENTER_LAT=9.0320
NEXT_PUBLIC_DEFAULT_MAP_CENTER_LNG=38.7469

# ==================== ANALYTICS & MONITORING ====================

# Google Analytics tracking ID (optional)
# Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_TRACKING_ID=

# Sentry DSN for error tracking (optional)
# Get from: https://sentry.io/
NEXT_PUBLIC_SENTRY_DSN=

# ==================== IPFS CONFIGURATION ====================

# IPFS Gateway URL for accessing documents
# Development:
#   NEXT_PUBLIC_IPFS_GATEWAY=http://localhost:8080/ipfs/
# Production (via nginx):
#   NEXT_PUBLIC_IPFS_GATEWAY=http://10.3.15.7/ipfs/
# Production (with domain):
#   NEXT_PUBLIC_IPFS_GATEWAY=https://coffeex.cbe.com.et/ipfs/

NEXT_PUBLIC_IPFS_GATEWAY=http://localhost:8080/ipfs/

# Production - Uncomment ONE of these:
# NEXT_PUBLIC_IPFS_GATEWAY=http://10.3.15.7/ipfs/
# NEXT_PUBLIC_IPFS_GATEWAY=https://coffeex.cbe.com.et/ipfs/

# ==================== LOCALIZATION ====================

# Default language
NEXT_PUBLIC_DEFAULT_LOCALE=en

# Supported languages
NEXT_PUBLIC_SUPPORTED_LOCALES=en,am

# ==================== SECURITY ====================

# CORS Origins (for API calls)
# Development:
#   NEXT_PUBLIC_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
# Production:
#   NEXT_PUBLIC_ALLOWED_ORIGINS=http://10.3.15.7,https://coffee.cecbs.et

NEXT_PUBLIC_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Production - Uncomment and customize:
# NEXT_PUBLIC_ALLOWED_ORIGINS=http://10.3.15.7,https://coffeex.cbe.com.et

# ==================== SESSION CONFIG ====================

# Session timeout (in minutes)
NEXT_PUBLIC_SESSION_TIMEOUT=30

# Remember me duration (in days)
NEXT_PUBLIC_REMEMBER_ME_DAYS=30

# ==================== UI THEME ====================

# Default theme: light | dark | auto
NEXT_PUBLIC_DEFAULT_THEME=light

# Enable theme switcher
NEXT_PUBLIC_ENABLE_THEME_SWITCHER=true

# ==================== FILE UPLOAD ====================

# Maximum file upload size (in MB)
NEXT_PUBLIC_MAX_FILE_SIZE=50

# Allowed file types for uploads
NEXT_PUBLIC_ALLOWED_FILE_TYPES=pdf,doc,docx,xls,xlsx,jpg,jpeg,png,zip

# ==================== PAGINATION ====================

# Default items per page
NEXT_PUBLIC_DEFAULT_PAGE_SIZE=20

# Available page size options
NEXT_PUBLIC_PAGE_SIZE_OPTIONS=10,20,50,100

# ==================== DATE/TIME ====================

# Default date format
NEXT_PUBLIC_DATE_FORMAT=YYYY-MM-DD

# Default time format
NEXT_PUBLIC_TIME_FORMAT=HH:mm:ss

# Timezone (Ethiopia)
NEXT_PUBLIC_TIMEZONE=Africa/Addis_Ababa

# ==================== BLOCKCHAIN CONFIG ====================

# Blockchain network name
NEXT_PUBLIC_BLOCKCHAIN_NETWORK=coffeechannel

# Blockchain explorer (if available)
# NEXT_PUBLIC_BLOCKCHAIN_EXPLORER=http://10.3.15.7:8081

# ==================== PRODUCTION DEPLOYMENT NOTES ====================
#
# When deploying to production server (10.3.15.7):
#
# 1. Create .env.production file with:
#    NEXT_PUBLIC_API_BASE_URL=http://10.3.15.7/api/v1
#    NEXT_PUBLIC_WS_URL=ws://10.3.15.7/socket.io
#    NEXT_PUBLIC_IPFS_GATEWAY=http://10.3.15.7/ipfs/
#    NEXT_PUBLIC_ALLOWED_ORIGINS=http://10.3.15.7
#
# 2. For SSL/HTTPS (after setting up domain):
#    NEXT_PUBLIC_API_BASE_URL=https://coffeex.cbe.com.et/api/v1
#    NEXT_PUBLIC_WS_URL=wss://coffeex.cbe.com.et/socket.io
#    NEXT_PUBLIC_IPFS_GATEWAY=https://coffeex.cbe.com.et/ipfs/
#    NEXT_PUBLIC_ALLOWED_ORIGINS=https://coffeex.cbe.com.et
#
# 3. Build the application:
#    npm run build
#
# 4. Start production server:
#    npm start
#
# ============================================================
