# ============================================================
# CECBS Next.js UI - Production Environment Configuration
# Domain: coffeex.cbe.com.et (Server: 10.3.15.7)
# ============================================================
# 
# INSTRUCTIONS:
# 1. Copy this file to .env.production on production server
# 2. Choose HTTP or HTTPS configuration based on your setup
# 3. Never commit .env.production to git
#
# ============================================================

# ==================== PRODUCTION MODE ====================
NODE_ENV=production

# ==================== API CONFIGURATION ====================

# OPTION 1: Production HTTP (via IP)
# NEXT_PUBLIC_API_BASE_URL=http://10.3.15.7/api/v1

# OPTION 2: Production HTTPS (via domain - RECOMMENDED)
NEXT_PUBLIC_API_BASE_URL=https://coffeex.cbe.com.et/api/v1

# ==================== WEBSOCKET CONFIGURATION ====================

# OPTION 1: WebSocket HTTP
# NEXT_PUBLIC_WS_URL=ws://10.3.15.7/socket.io

# OPTION 2: WebSocket HTTPS (RECOMMENDED)
NEXT_PUBLIC_WS_URL=wss://coffeex.cbe.com.et/socket.io

# ==================== APPLICATION INFO ====================

NEXT_PUBLIC_APP_NAME=CoffeeX CECBS
NEXT_PUBLIC_APP_VERSION=1.2.0
NEXT_PUBLIC_APP_DESCRIPTION=Ethiopian Coffee Export Consortium Blockchain System

# ==================== FEATURE FLAGS ====================

# Enable production features
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_WEBSOCKET=true
NEXT_PUBLIC_ENABLE_QR_CODE=true
NEXT_PUBLIC_ENABLE_BLOCKCHAIN_EXPLORER=true
NEXT_PUBLIC_ENABLE_IPFS=true

# ==================== ORGANIZATION CONFIG ====================

# Default organization portal on login
NEXT_PUBLIC_DEFAULT_ORG=ECTA

# Supported organizations
NEXT_PUBLIC_SUPPORTED_ORGS=ECTA,ECX,NBE,BANKS,CUSTOMS,SHIPPING

# ==================== IPFS CONFIGURATION ====================

# OPTION 1: IPFS via IP
# NEXT_PUBLIC_IPFS_GATEWAY=http://10.3.15.7/ipfs/

# OPTION 2: IPFS via domain (RECOMMENDED)
NEXT_PUBLIC_IPFS_GATEWAY=https://coffeex.cbe.com.et/ipfs/

# ==================== SECURITY ====================

# CORS Origins
# OPTION 1: HTTP
# NEXT_PUBLIC_ALLOWED_ORIGINS=http://10.3.15.7

# OPTION 2: HTTPS (RECOMMENDED)
NEXT_PUBLIC_ALLOWED_ORIGINS=https://coffeex.cbe.com.et

# ==================== SESSION CONFIG ====================

# Session timeout (in minutes)
NEXT_PUBLIC_SESSION_TIMEOUT=60

# Remember me duration (in days)
NEXT_PUBLIC_REMEMBER_ME_DAYS=30

# ==================== UI THEME ====================

# Default theme
NEXT_PUBLIC_DEFAULT_THEME=light

# Enable theme switcher
NEXT_PUBLIC_ENABLE_THEME_SWITCHER=true

# ==================== FILE UPLOAD ====================

# Maximum file upload size (in MB)
NEXT_PUBLIC_MAX_FILE_SIZE=50

# Allowed file types for uploads
NEXT_PUBLIC_ALLOWED_FILE_TYPES=pdf,doc,docx,xls,xlsx,jpg,jpeg,png,zip

# ==================== PAGINATION ====================

# Default items per page
NEXT_PUBLIC_DEFAULT_PAGE_SIZE=20

# Available page size options
NEXT_PUBLIC_PAGE_SIZE_OPTIONS=10,20,50,100

# ==================== DATE/TIME ====================

# Default date format
NEXT_PUBLIC_DATE_FORMAT=YYYY-MM-DD

# Default time format
NEXT_PUBLIC_TIME_FORMAT=HH:mm:ss

# Timezone (Ethiopia)
NEXT_PUBLIC_TIMEZONE=Africa/Addis_Ababa

# ==================== BLOCKCHAIN CONFIG ====================

# Blockchain network name
NEXT_PUBLIC_BLOCKCHAIN_NETWORK=coffeechannel

# ==================== ANALYTICS & MONITORING ====================

# Enable production monitoring
NEXT_PUBLIC_ENABLE_ERROR_REPORTING=true

# ==================== LOCALIZATION ====================

# Default language
NEXT_PUBLIC_DEFAULT_LOCALE=en

# Supported languages
NEXT_PUBLIC_SUPPORTED_LOCALES=en,am

# ============================================================
# QUICK DEPLOYMENT COMMANDS
# ============================================================
#
# 1. Copy to production server:
#    scp .env.production.example root@10.3.15.7:/opt/cecbs/ui/.env.production
#
# 2. Build application:
#    cd /opt/cecbs/ui && npm run build
#
# 3. Start production server:
#    cd /opt/cecbs/ui && npm start
#
# ============================================================