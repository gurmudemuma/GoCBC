{
  "name": "cecbs-ui",
  "version": "1.2.0",
  "description": "Ethiopian Coffee Export Consortium Blockchain System - Web UI",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "type-check": "tsc --noEmit",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "docker:build": "docker build -t cecbs-ui:latest .",
    "docker:run": "docker run -p 3000:3000 cecbs-ui:latest"
  },
  "dependencies": {
    "@emotion/react": "^11.11.3",
