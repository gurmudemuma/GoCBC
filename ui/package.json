    "@mui/lab": "^5.0.0-alpha.161",
    "@mui/material": "^5.15.3",
    "@mui/x-data-grid": "^6.18.7",
    "@mui/x-date-pickers": "^6.20.2",
    "antd": "^6.5.0",
    "axios": "^1.6.5",
    "date-fns": "^3.0.6",
    "dayjs": "^1.11.21",
    "jwt-decode": "^4.0.0",
    "next": "^14.0.4",
    "qrcode.react": "^3.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.49.3",
    "react-toastify": "^9.1.3",
    "recharts": "^2.15.4",
